{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "index.html",
          "이츠페이_관리자_시스템_10.html",
          "css/**",
          "js/**",
          "logo.png",
          "구글.png",
          "네이버.png",
          "카카오톡.png"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
